{
  "name": "bookleaf-support-backend",
  "version": "0.1.0",
  "description": "BookLeaf AI-assisted author support backend (Node.js + Express + TypeScript + MongoDB).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json --noEmit",
    "seed": "ts-node --project scripts/tsconfig.json scripts/seed.ts",
    "socket:smoke": "ts-node --project scripts/tsconfig.json scripts/socket-smoke.ts",
    "ping": "ts-node --project scripts/tsconfig.json scripts/ping.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "bookleaf",
    "support",
    "backend",
    "express",
    "typescript",
    "mongodb"
  ],
  "author": "BookLeaf",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@google/genai": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.8.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.7",
    "pino-pretty": "^11.3.0",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
